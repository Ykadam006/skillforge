// Neon PostgreSQL — set DATABASE_URL in .env.local (see .env.example).
// Run: npx prisma generate && npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Single-row JSON snapshot for cloud backup / multi-device (optional API sync).
/// Normalized Skill / Project tables can be added later.
model SkillforgeState {
  id        String   @id @default("default")
  revision  Int      @default(0)
  payload   Json
  updatedAt DateTime @updatedAt
}
